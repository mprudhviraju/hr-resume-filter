# Copy to .env and fill in values
OPENAI_API_KEY=

# Optional — chat model id (default: gpt-4o). Examples: gpt-4o-mini, gpt-4.1, gpt-5
OPENAI_MODEL=

# API port for local dev — default 8787 if omitted.
# Change this only if 8787 is taken; if you change PORT, also update client/vite.config.ts proxy target.
# macOS: 5000 is often AirPlay; 8080 is often used by other tools.
PORT=8787

# --- AWS / Lambda (optional for local dev) ---
# JOB_TABLE_NAME=hr-resume-filter-api-jobs
# ALLOWED_ORIGINS=http://localhost:3000
# DATABASE_URL=postgresql://...  # optional; falls back to OPENAI_API_KEY
